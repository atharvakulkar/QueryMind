# Copy to ".env" and fill in values. Never commit real credentials.

# Required: async PostgreSQL URL (Neon, Supabase, or local Postgres).
DATABASE_URL=postgresql://readonly_user:CHANGE_ME@127.0.0.1:5432/your_database

# Optional application tuning
APP_NAME=QueryMind
LOG_LEVEL=INFO

# Cap rows returned by the API / internal execute endpoint
MAX_QUERY_ROWS=500

# Server-side statement timeout (seconds) applied on each pooled connection
STATEMENT_TIMEOUT_SECONDS=30

# Dev-only: allow POST /api/v1/internal/execute-read with ad-hoc SELECT (default off)
ALLOW_ADHOC_SQL=false

# Agent (Phase 3) — Groq via LangChain
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
AGENT_MAX_RETRIES=3
LOG_AGENT_SQL=true

# Streamlit (Phase 4) — optional override for API URL when running the UI
# QUERYMIND_API_URL=http://127.0.0.1:8000
